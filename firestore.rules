rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMaster() {
      return isAuth() && getUser().role == 'master';
    }

    // isVisible: a player can read if mode is 'all', OR if their UID is in playerIds.
    // We intentionally drop the mode=='specific' check here so that Firestore's query
    // planner can prove that "array-contains uid" is always safe — the app code ensures
    // playerIds is only ever non-empty when mode=='specific', making these equivalent.
    function isVisible() {
      return resource.data.visibility.mode == 'all' ||
        request.auth.uid in resource.data.visibility.playerIds;
    }

    // Perfis de usuário — todos autenticados podem ler (grupo fechado de confiança)
    match /users/{uid} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.auth.uid == uid;
      // O próprio usuário ou o mestre (edição de ficha de jogador)
      allow update: if isAuth() && (request.auth.uid == uid || isMaster());

      // Notificações de revelação — mestre cria, jogador lê/atualiza as próprias
      match /notifications/{notifId} {
        allow read, update, delete: if isAuth() && request.auth.uid == uid;
        allow create: if isAuth() && isMaster();
      }
    }

    // Campanha e sub-coleções
    match /campaigns/{campaignId} {
      allow read, write: if isMaster();

      match /characters/{id} {
        allow read, write: if isMaster();
        allow read: if isAuth() && isVisible();
      }
      match /locations/{id} {
        allow read, write: if isMaster();
        allow read: if isAuth() && isVisible();
      }
      match /events/{id} {
        allow read, write: if isMaster();
        allow read: if isAuth() && isVisible();
      }
      match /factions/{id} {
        allow read, write: if isMaster();
        allow read: if isAuth() && isVisible();
      }
      // Relações — jogadores criam laços próprios (createdBy) e gerenciam
      // apenas os seus; o mestre controla a visibilidade de todas
      match /relations/{id} {
        allow read, write: if isMaster();
        allow read: if isAuth() &&
          (isVisible() || resource.data.createdBy == request.auth.uid);
        allow create: if isAuth() &&
          request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if isAuth() &&
          resource.data.createdBy == request.auth.uid;
      }

      match /documents/{id} {
        allow read, write: if isMaster();
        allow read: if isAuth() && isVisible();
      }
      match /items/{id} {
        allow read, write: if isMaster();
        allow read: if isAuth() && isVisible();
      }

      match /npcs/{id} {
        allow read, write: if isMaster();
      }

      // Navio do grupo — todos os autenticados leem; só o mestre edita
      match /ship/{id} {
        allow read:  if isAuth();
        allow write: if isMaster();
      }

      // Anotações — todos autenticados podem ler e criar as próprias
      match /annotations/{id} {
        allow read:   if isAuth();
        allow create: if isAuth() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isAuth() &&
          (isMaster() || resource.data.authorId == request.auth.uid);
      }
    }
  }
}
