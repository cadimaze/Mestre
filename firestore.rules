rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMaster() {
      return isAuth() && getUser().role == 'master';
    }

    // Visível se liberado para todos ou se o uid está na lista de liberados.
    // (playerIds só é preenchido quando o modo é 'specific' — o app limpa a
    // lista nos outros modos, permitindo consultas compatíveis com as regras)
    function isVisible() {
      return resource.data.visibility.mode == 'all' ||
        request.auth.uid in resource.data.visibility.playerIds;
    }

    // Perfis de usuário — leitura liberada para autenticados
    // (necessário para listar os personagens dos jogadores e laços entre eles)
    match /users/{uid} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.auth.uid == uid;
      allow update: if isAuth() && request.auth.uid == uid;
    }

    // Campanha e sub-coleções
    match /campaigns/{campaignId} {
      allow read, write: if isMaster();

      match /characters/{id} {
        allow read, write: if isMaster();
        allow read: if isAuth() && isVisible();
      }
      match /locations/{id} {
        allow read, write: if isMaster();
        allow read: if isAuth() && isVisible();
      }
      match /events/{id} {
        allow read, write: if isMaster();
        allow read: if isAuth() && isVisible();
      }
      match /factions/{id} {
        allow read, write: if isMaster();
        allow read: if isAuth() && isVisible();
      }

      // Relações — jogadores criam laços próprios e gerenciam apenas os seus;
      // o mestre controla a visibilidade de todas
      match /relations/{id} {
        allow read, write: if isMaster();
        allow read: if isAuth() &&
          (isVisible() || resource.data.createdBy == request.auth.uid);
        allow create: if isAuth() &&
          request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if isAuth() &&
          resource.data.createdBy == request.auth.uid;
      }

      // Anotações — todos autenticados podem ler e criar as próprias
      match /annotations/{id} {
        allow read:   if isAuth();
        allow create: if isAuth() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isAuth() &&
          (isMaster() || resource.data.authorId == request.auth.uid);
      }
    }
  }
}
